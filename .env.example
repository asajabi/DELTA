DJANGO_SECRET_KEY=replace-with-a-secure-random-secret
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost,.ngrok-free.dev
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,https://*.ngrok-free.dev
DJANGO_SECURE_COOKIES=True
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=True
DJANGO_LOG_LEVEL=INFO
# Optional DB override (default is sqlite db.sqlite3)
# DJANGO_DB_ENGINE=sqlite3
# DJANGO_DB_NAME=
# DJANGO_SQLITE_PATH=
# DJANGO_SQLITE_TIMEOUT_SECONDS=20
# DJANGO_DB_USER=
# DJANGO_DB_PASSWORD=
# DJANGO_DB_HOST=
# DJANGO_DB_PORT=
# DJANGO_DB_COLLATION=utf8mb4_unicode_ci
# SMACC_WEBHOOK_IP_ALLOWLIST=
# SMACC_WEBHOOK_RATE_LIMIT_PER_MINUTE=120
# SMACC_WEBHOOK_SIGNATURE_HEADER=X-Smacc-Signature
# AI assistant (live LLM for Chat Assistant)
# AI_ASSISTANT_ENABLED=True
# AI_ASSISTANT_PROVIDER=openai
# AI_ASSISTANT_MODEL=gpt-4.1-mini
# AI_ASSISTANT_API_KEY=
# AI_ASSISTANT_BASE_URL=https://api.openai.com/v1
# AI_ASSISTANT_TIMEOUT_SECONDS=20

# Email / SMTP (for forgot-password OTP)
# Gmail example:
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# DJANGO_EMAIL_HOST=smtp.gmail.com
# DJANGO_EMAIL_PORT=587
# DJANGO_EMAIL_USE_TLS=True
# DJANGO_EMAIL_USE_SSL=False
# DJANGO_EMAIL_HOST_USER=your-account@gmail.com
# DJANGO_EMAIL_HOST_PASSWORD=your-app-password
# DJANGO_DEFAULT_FROM_EMAIL=DELTA POS <your-account@gmail.com>
# DJANGO_SERVER_EMAIL=your-account@gmail.com
